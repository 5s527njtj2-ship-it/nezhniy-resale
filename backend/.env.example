# Скопируйте в .env и заполните своими значениями

# Сервер
PORT=3001
FRONTEND_URL=https://ваш-домен.ru

# Пароль владельца магазина
OWNER_PASSWORD=замените_на_свой_пароль

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
OWNER_EMAIL=владелец@example.com
FROM_EMAIL=noreply@ваш-домен.ru

# Telegram Bot
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
